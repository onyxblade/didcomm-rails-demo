<h1>Messages</h1>

<%= link_to "New Message", new_message_path %>

<% if @messages.any? %>
  <table>
    <thead>
      <tr>
        <th>Direction</th>
        <th>From</th>
        <th>To</th>
        <th>Body</th>
        <th>Status</th>
        <th>Visibility</th>
        <th>Time</th>
      </tr>
    </thead>
    <tbody>
      <% @messages.each do |msg| %>
        <tr>
          <td><span class="badge badge-<%= msg.direction %>"><%= msg.direction %></span></td>
          <td class="mono"><%= truncate(msg.from_did || "-", length: 30) %></td>
          <td class="mono"><%= truncate(msg.to_did || "-", length: 30) %></td>
          <td><%= link_to truncate(msg.body, length: 50), message_path(msg) %></td>
          <td><span class="badge badge-<%= msg.status %>"><%= msg.status %></span></td>
          <td><span class="badge badge-<%= msg.visibility %>"><%= msg.visibility %></span></td>
          <td><%= msg.created_at.strftime("%Y-%m-%d %H:%M") %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p>No messages yet.</p>
<% end %>
